#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"

STARTER_ROOT = File.expand_path("..", __dir__)
TEMPLATE_ROOT = File.join(STARTER_ROOT, "template")

PROFILES = {
  "1" => "api",
  "2" => "web",
  "3" => "web_auth"
}.freeze

RENDER_ROOTS = %w[
  .env.example
  .github
  .kamal
  Dockerfile
  Gemfile
  Procfile.dev
  README.md
  Rakefile
  app
  bin
  config
  config.ru
  db
  lib
  public
  test
].freeze

def copy_tree(source, destination)
  Dir.glob(File.join(source, "*"), File::FNM_DOTMATCH).each do |path|
    next if [ ".", ".." ].include?(File.basename(path))

    target = File.join(destination, File.basename(path))

    if File.directory?(path)
      FileUtils.mkdir_p(target)
      copy_tree(path, target)
    else
      FileUtils.rm_rf(target) if File.exist?(target) || File.symlink?(target)
      FileUtils.cp_r(path, target, preserve: true)
    end
  end
end

def app_slug(dir)
  File.basename(dir).downcase.gsub(/[^a-z0-9]+/, "_").gsub(/\A_|_\z/, "")
end

def app_module(dir) = app_slug(dir).split("_").map(&:capitalize).join
def app_title(dir)  = app_slug(dir).split("_").map(&:capitalize).join(" ")

def text_file?(path)
  return false unless File.file?(path)

  !(File.binread(path, 1024) || "").include?("\x00")
end

def render_placeholders(destination)
  replacements = {
    "__APP_MODULE__" => app_module(destination),
    "__APP_SLUG__"   => app_slug(destination),
    "__APP_TITLE__"  => app_title(destination)
  }

  RENDER_ROOTS.each do |entry|
    path = File.join(destination, entry)
    next unless File.exist?(path)

    files = File.directory?(path) ? Dir.glob(File.join(path, "**", "*"), File::FNM_DOTMATCH) : [ path ]
    files.each do |file|
      next unless text_file?(file)

      content = File.read(file)
      next unless replacements.keys.any? { |key| content.include?(key) }

      replacements.each { |key, value| content = content.gsub(key, value) }
      File.write(file, content)
    end
  end
end

def pick_profile
  puts "Choose a profile:"
  puts "  1. api"
  puts "  2. web"
  puts "  3. web_auth"
  print "> "
  PROFILES.fetch($stdin.gets&.strip.to_s) { abort "Invalid selection." }
end

# ── main ────────────────────────────────────────────────────────────────────

abort "Usage: bin/new <app-name-or-path>\n       bin/new todo-api\n       bin/new ~/Dev/personal/todo-api" if ARGV.empty?

app_path = File.expand_path(ARGV[0])
abort "Error: #{app_path} already exists." if File.exist?(app_path)

profile = pick_profile

puts "\nCreating #{File.basename(app_path)} (profile: #{profile})..."
FileUtils.mkdir_p(app_path)

copy_tree(File.join(TEMPLATE_ROOT, "base"), app_path)

case profile
when "api"
  copy_tree(File.join(TEMPLATE_ROOT, "profiles", "api"), app_path)
when "web"
  copy_tree(File.join(TEMPLATE_ROOT, "profiles", "web"), app_path)
when "web_auth"
  copy_tree(File.join(TEMPLATE_ROOT, "profiles", "web"), app_path)
  copy_tree(File.join(TEMPLATE_ROOT, "profiles", "web_auth"), app_path)
end

render_placeholders(app_path)

puts "Done.\n\n"
puts "Next steps:"
puts "  cd #{app_path}"
puts "  cp .env.example .env"
puts "  # edit .env with your DATABASE_URL, REDIS_URL#{", GOOGLE_CLIENT_ID/SECRET" if profile == "web_auth"}"
puts "  bin/setup"
puts "  bin/dev"
