#!/usr/bin/env bash
set -euo pipefail

if [[ ! -f .rails_starter_profile ]]; then
  echo "Run bin/bootstrap_app first."
  exit 1
fi

bundle check || bundle install
bin/rails db:prepare

if [[ "${1:-}" == "--reset" ]]; then
  bin/rails db:reset
fi

bin/rails log:clear tmp:clear

if [[ "${1:-}" != "--skip-server" ]]; then
  exec bin/dev
fi
