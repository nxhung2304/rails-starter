#!/usr/bin/env bash
set -euo pipefail

bundle check || bundle install
bin/rails db:prepare

if [[ "${1:-}" == "--reset" ]]; then
  bin/rails db:reset
fi

bin/rails log:clear tmp:clear

bundle exec rails --tasks 2>/dev/null | grep -q "tailwindcss:build" && bin/rails tailwindcss:build

if [[ "${1:-}" != "--skip-server" ]]; then
  exec bin/dev
fi
