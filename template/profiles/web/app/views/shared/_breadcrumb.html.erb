<% if breadcrumbs.any? %>
  <nav class="flex items-center gap-1.5 text-sm text-slate-500 mb-6">
    <%= link_to "Home", root_path, class: "hover:text-slate-900 transition-colors" %>
    <% breadcrumbs.each do |crumb| %>
      <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <% if crumb[:path] %>
        <%= link_to crumb[:label], crumb[:path], class: "hover:text-slate-900 transition-colors" %>
      <% else %>
        <span class="text-slate-900 font-medium"><%= crumb[:label] %></span>
      <% end %>
    <% end %>
  </nav>
<% end %>
