<section class="mx-auto max-w-3xl px-6 py-16">
  <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Dashboard</p>
  <h1 class="text-4xl font-bold tracking-tight text-slate-900">Welcome, <%= current_user.email %>!</h1>
  <p class="mt-4 text-lg text-slate-600">
    You have successfully signed in to __APP_TITLE__.
  </p>
  <div class="mt-8 flex gap-4">
    <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
  </div>
</section>
